<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApphotel.Resources.Views.Sobre"
             Title="Sobre"
    Shell.NavBarIsVisible="false">
    
        <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFB6C1" Offset="0.0"/>
            <GradientStop Color="#FF69B4" Offset="1.0"/>
        </LinearGradientBrush>
    </ContentPage.Background>
    <VerticalStackLayout>
        <Label 
            
          Text="Sobre"
        TextDecorations="Underline"
        VerticalOptions="Center" 
        HorizontalOptions="Center" 
        FontFamily="Kalam"
        TextColor="DarkMagenta"
        FontSize="Title"
            Padding="100"
           />
        <VerticalStackLayout Spacing="1"
                             HorizontalOptions="CenterAndExpand">

            <Label Text="Desenvolvido por:"
                       FontAttributes="Bold"
                       FontSize="18"
                   TextColor="White"/>

            <Label Text="Caroline Schramm De Camargo"
                       FontSize="Micro"
                   TextColor="DarkMagenta"/>

            <Label Text="Ano do desenvolvimento:"
                       FontAttributes="Bold"
                       FontSize="18"
                   TextColor="White"/>

            <Label Text="2026"
                       FontSize="Micro"
                    TextColor="DarkMagenta"/>

        </VerticalStackLayout>
        <Button Text="Voltar"
                Padding="10"
                BackgroundColor="MediumVioletRed"
                Clicked="ButtonVoltar_Clicked"></Button>
       
    </VerticalStackLayout>
        
</ContentPage>
